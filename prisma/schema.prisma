// Prisma schema for the UA agency platform.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  MANAGER
  PROJECT_MANAGER
  DEVELOPER
  DESIGNER
}

// Which discipline a user serves in on a specific project.
enum ProjectRole {
  PROJECT_MANAGER
  DEVELOPER
  DESIGNER
}

enum ClientSource {
  UPWORK
  AGENCY
  REFERRAL
  OTHER
}

enum ProjectType {
  DESIGN
  DEVELOPMENT
  SOFTWARE
}

enum BudgetType {
  FIXED
  HOURLY
  RETAINER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  ONBOARDING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  PAYPAL
  CASH
  CRYPTO
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  roles        Role[]   @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTasks    Task[]          @relation("TaskAssignee")
  timeEntries      TimeEntry[]
  projectMembers   ProjectMember[]

  @@index([email])
}

model Client {
  id           String        @id @default(cuid())
  // Contact
  name         String        // business / client name
  contactName  String?       // primary contact person
  email        String?
  phone        String?
  source       ClientSource?
  sourceOther  String?       // when source = OTHER
  industry     String?
  location     String?       // optional geographic location
  website      String?       // current website
  socialLinks  String?       // free text / links
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  projects Project[]
  payments Payment[]
}

model Project {
  id              String        @id @default(cuid())
  name            String
  type            ProjectType
  description     String?
  targetAudience  String?
  referenceLinks  String?

  // Budget
  budgetAmount    Float?
  budgetCurrency  String?       @default("USD")
  budgetType      BudgetType?

  // Timeline
  startDate       DateTime?
  deadline        DateTime?
  priority        Priority      @default(MEDIUM)

  // Assets & links (v1 = links only)
  figmaLink       String?
  fileLinks       String?       // pasted URLs, one per line
  brandAssetsLink String?
  domainAccess    String?       // notes / access for dev projects

  status          ProjectStatus @default(ONBOARDING)
  internalNotes   String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  members     ProjectMember[]
  tasks       Task[]
  timeEntries TimeEntry[]
  payments    Payment[]

  @@index([clientId])
  @@index([status])
}

// Join: a user assigned to a project in a particular discipline.
// Multiple people per role, and a person could hold multiple roles on a project.
model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectRole
  createdAt DateTime    @default(now())

  @@unique([projectId, userId, role])
  @@index([projectId])
  @@index([userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model TimeEntry {
  id         String   @id @default(cuid())
  checkInAt  DateTime
  checkOutAt DateTime
  hours      Float
  tasks      String?
  notes      String?
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// A payment received from a client (optionally tied to a specific project).
model Payment {
  id        String        @id @default(cuid())
  amount    Float
  currency  String        @default("USD")
  amountCad Float?        // amount converted to CAD at the rate when recorded
  fxRate    Float?        // currency -> CAD rate used at record time
  method    PaymentMethod @default(BANK_TRANSFER)
  paidAt    DateTime
  note      String?
  createdAt DateTime      @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
}
