// Prisma schema for the UA agency platform.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  MANAGER
  PROJECT_MANAGER
  DEVELOPER
  DESIGNER
  SALES
}

// Which discipline a user serves in on a specific project.
enum ProjectRole {
  PROJECT_MANAGER
  DEVELOPER
  DESIGNER
}

enum BudgetType {
  FIXED
  HOURLY
  RETAINER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  ONBOARDING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  roles        Role[]   @default([])
  timezone     String?  // IANA tz of where this person works, e.g. "Asia/Karachi"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTasks     Task[]             @relation("TaskAssignee")
  timeEntries       TimeEntry[]
  projectMembers    ProjectMember[]
  salesLeads        Client[]           @relation("SalesLeads")
  commissionPayouts CommissionPayout[]
  salaries          Salary[]
  salaryPayments    SalaryPayment[]
  expensesPaid      Expense[]          @relation("ExpensePaidBy")
  leaveRequests     LeaveRequest[]     @relation("UserLeave")
  uploadedFiles     FileAsset[]        @relation("UploadedFiles")
  fileComments      FileComment[]      @relation("FileComments")
  assistantMessages AssistantMessage[] @relation("AssistantMessages")
  loginsCreated     Login[]            @relation("LoginCreatedBy")
  loginShares       LoginShare[]       @relation("LoginShares")
  notifications     Notification[]     @relation("Notifications")
  conversationMemberships ConversationMember[] @relation("ConversationMemberships")
  messagesSent      Message[]          @relation("MessagesSent")
  commentThreads    CommentThread[]    @relation("ThreadCreatedBy")
  comments          Comment[]          @relation("CommentAuthor")

  @@index([email])
}

// Resolvable comment threads (Figma-style) attachable to any entity
// (project / task / client). The first comment opens the thread; the rest are
// replies. @mentions notify the tagged user.
model CommentThread {
  id          String    @id @default(cuid())
  entityType  String // 'project' | 'task' | 'client'
  entityId    String
  resolved    Boolean   @default(false)
  createdById String?
  createdBy   User?     @relation("ThreadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([entityType, entityId])
}

model Comment {
  id        String        @id @default(cuid())
  threadId  String
  thread    CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?         @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime      @default(now())

  @@index([threadId, createdAt])
}

// Direct & group messaging.
model Conversation {
  id          String               @id @default(cuid())
  isGroup     Boolean              @default(false)
  title       String?
  createdById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     ConversationMember[]
  messages    Message[]
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("ConversationMemberships", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  deletedAt      DateTime? // soft-delete: hidden from the list, kept for 30 days
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String?
  sender         User?        @relation("MessagesSent", fields: [senderId], references: [id], onDelete: SetNull)
  body           String
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// In-app notifications (mentions, approvals, shares, leave requests, …).
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("Notifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// Shared login credentials (a small team vault). Passwords are stored encrypted
// (AES-256-GCM) and only decrypted on demand for authorized users.
model Login {
  id          String       @id @default(cuid())
  name        String
  url         String?
  username    String?
  passwordEnc String // encrypted blob — never the plaintext
  notes       String?
  createdById String?
  createdBy   User?        @relation("LoginCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  shares      LoginShare[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([createdById])
}

// Who a given login is shared with. Managers (super admin / admin / PM) see all.
model LoginShare {
  id        String   @id @default(cuid())
  loginId   String
  login     Login    @relation(fields: [loginId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("LoginShares", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([loginId, userId])
  @@index([userId])
}

// Persisted analytics-assistant chat, per user. Token/cost columns power the
// super-admin "credits used" view; everyone can read their own history.
model AssistantMessage {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation("AssistantMessages", fields: [userId], references: [id], onDelete: Cascade)
  role             String // 'user' | 'assistant'
  content          String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  costUsd          Float    @default(0)
  model            String?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
}

model Client {
  id           String        @id @default(cuid())
  // Contact
  name         String        // business / client name
  contactName  String?       // primary contact person
  email        String?
  phone        String?
  source       String?
  sourceOther  String?       // when source = OTHER
  industry     String?
  location     String?       // optional geographic location
  website      String?       // current website
  socialLinks  String?       // free text / links
  notes        String?
  // Lead attribution for sales commission
  leadType      String?
  taxRegion     String?   // 'QC' | 'CA' | 'US' — drives invoice tax
  salespersonId String?
  salesperson   User?     @relation("SalesLeads", fields: [salespersonId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  projects Project[]
  payments Payment[]
  invoices Invoice[]

  // Set when this client was converted from a sourced Lead.
  convertedFromLead Lead? @relation("LeadConversion")

  @@index([salespersonId])
}

model Project {
  id              String        @id @default(cuid())
  name            String
  type            String
  description     String?
  targetAudience  String?
  referenceLinks  String?

  // Budget
  budgetAmount    Float?
  budgetCurrency  String?       @default("USD")
  budgetType      BudgetType?

  // Timeline
  startDate       DateTime?
  deadline        DateTime?
  priority        Priority      @default(MEDIUM)

  // Assets & links (v1 = links only)
  figmaLink       String?
  fileLinks       String?       // pasted URLs, one per line
  brandAssetsLink String?
  domainAccess    String?       // notes / access for dev projects

  status          ProjectStatus @default(ONBOARDING)
  internalNotes   String?
  pmCommissionRate Float        @default(10) // % of project value / payments to the PM

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  members     ProjectMember[]
  tasks       Task[]
  timeEntries TimeEntry[]
  payments    Payment[]
  invoices    Invoice[]
  files       FileAsset[]

  @@index([clientId])
  @@index([status])
}

// Join: a user assigned to a project in a particular discipline.
// Multiple people per role, and a person could hold multiple roles on a project.
model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectRole
  createdAt DateTime    @default(now())

  @@unique([projectId, userId, role])
  @@index([projectId])
  @@index([userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  tags Tag[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#64748b")
  createdAt DateTime @default(now())

  tasks Task[]
}

// User-editable dropdown options. `kind` groups them (projectType, clientSource,
// expenseCategory, fileCategory, paymentMethod, currency, leadType). `value` is
// the stored string; `label` is shown; `rate` is the commission % for leadType.
// Singleton company profile (used on invoices, receipts, contracts).
model CompanySetting {
  id        String   @id @default("default")
  name      String   @default("UA Agency")
  email     String?
  phone     String?
  website   String?
  address   String?
  gstNumber String?
  qstNumber String?
  neqNumber String?
  gstRate   Float    @default(5)
  qstRate   Float    @default(9.975)
  updatedAt DateTime @updatedAt
}

model OptionItem {
  id        String   @id @default(cuid())
  kind      String
  value     String
  label     String
  rate      Float?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([kind, value])
  @@index([kind])
}

// A recorded commission payout to a team member (sales or PM). Amount in CAD.
model CommissionPayout {
  id        String   @id @default(cuid())
  amount    Float
  paidAt    DateTime
  method    String?
  note      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A file stored in the Google Shared Drive, indexed against a project.
model FileAsset {
  id          String       @id @default(cuid())
  name        String
  category    String       @default("OTHER")
  driveFileId String
  webViewLink String?
  mimeType    String?
  size        Int?
  createdAt   DateTime     @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: SetNull)

  comments FileComment[]

  @@index([projectId])
}

model FileComment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  fileId String
  file   FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?    @relation("FileComments", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([fileId])
}

// An invoice for a project (or client). Number auto-increments.
model Invoice {
  id        String        @id @default(cuid())
  number    Int           @unique @default(autoincrement())
  status    InvoiceStatus @default(DRAFT)
  amount    Float
  currency  String        @default("USD")
  issuedAt  DateTime      @default(now())
  dueAt     DateTime?
  notes     String?
  sentAt    DateTime?
  createdAt DateTime      @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
}

// A business expense (any currency, normalized to CAD).
model Expense {
  id        String          @id @default(cuid())
  title     String
  category  String          @default("OTHER")
  amount    Float
  currency  String          @default("CAD")
  amountCad Float?
  fxRate    Float?
  date      DateTime        // the date the expense applies to
  note      String?
  createdAt DateTime        @default(now())

  // Who fronted the money. null = paid by the company directly.
  paidById     String?
  paidBy       User?     @relation("ExpensePaidBy", fields: [paidById], references: [id], onDelete: SetNull)
  reimbursed   Boolean   @default(false) // only meaningful when paidById is set
  reimbursedAt DateTime?

  @@index([date])
  @@index([paidById])
}

// Money the company has given out (advances, loans, opening balances) that
// still has to be recovered. Outstanding = amountCad − recoveredAmount.
model Loan {
  id              String   @id @default(cuid())
  counterparty    String   // who received it / who owes it back
  note            String?
  amount          Float
  currency        String   @default("CAD")
  amountCad       Float?
  recoveredAmount Float    @default(0) // total recovered so far, in CAD
  givenAt         DateTime
  createdAt       DateTime @default(now())

  @@index([givenAt])
}

// Salary progression: one row per salary change for a user (latest = current).
model Salary {
  id            String   @id @default(cuid())
  amount        Float
  currency      String   @default("CAD")
  effectiveFrom DateTime
  note          String?
  createdAt     DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A salary payment to a user (any currency, normalized to CAD).
model SalaryPayment {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("CAD")
  amountCad Float?
  paidAt    DateTime
  method    String?
  note      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A check-in / check-out session. checkOutAt null = still checked in (open).
model TimeEntry {
  id            String    @id @default(cuid())
  checkInAt     DateTime
  checkOutAt    DateTime?
  hours         Float?
  tasks         String?
  notes         String?
  source        String    @default("SELF") // SELF | ADMIN
  activeSeconds Int       @default(0) // accumulated active (non-idle) time
  createdAt     DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// Vacation / sick / absence. Members request (PENDING); admins approve/reject,
// or add an absence directly (created APPROVED).
model LeaveRequest {
  id          String    @id @default(cuid())
  type        String    @default("VACATION") // VACATION | SICK | ABSENT | UNPAID | OTHER
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  createdById String?
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())

  userId String
  user   User   @relation("UserLeave", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// Lightweight audit of task changes, used to auto-fill "tasks done" at checkout.
// Stored as denormalized snapshots so it survives task/project deletion.
model TaskActivity {
  id        String   @id @default(cuid())
  userId    String?
  taskId    String?
  projectId String?
  summary   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// A payment received from a client (optionally tied to a specific project).
model Payment {
  id        String        @id @default(cuid())
  amount    Float
  currency  String        @default("USD")
  amountCad Float?        // amount converted to CAD at the rate when recorded
  fxRate    Float?        // currency -> CAD rate used at record time
  method    String        @default("BANK_TRANSFER")
  paidAt    DateTime
  note      String?
  createdAt DateTime      @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
}

// ─── Lead generation ─────────────────────────────────────────────────────────
// Sourced prospects (pre-Client). A "won" lead converts into a Client above.

// A target company a lead works at.
model LeadCompany {
  id            String   @id @default(cuid())
  name          String
  domain        String?  @unique
  industry      String?
  employeeCount Int?
  location      String?
  linkedinUrl   String?
  description   String?
  createdAt     DateTime @default(now())

  leads Lead[]
}

// A sourced person (the prospect we contact).
model Lead {
  id          String   @id @default(cuid())
  firstName   String?
  lastName    String?
  title       String?
  email       String?  @unique
  emailStatus String   @default("unknown") // unknown | verified | risky | invalid
  phone       String?
  linkedinUrl String?

  source     String  @default("apollo")
  externalId String? @unique // provider dedupe key (e.g. Apollo person id)
  segment    String? // which ICP segment this lead was sourced for

  score      Int     @default(0)
  status     String  @default("new") // new | scored | queued | contacted | replied | won | lost | unqualified
  smsConsent Boolean @default(false) // TCPA: only true if opted in

  companyId String?
  company   LeadCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Set once this lead is converted into a real Client.
  convertedClientId String? @unique
  convertedClient   Client? @relation("LeadConversion", fields: [convertedClientId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities  LeadActivity[]
  enrollments SequenceEnrollment[]

  @@index([status])
  @@index([segment])
  @@index([companyId])
}

// A reusable multi-step outreach campaign (one per ICP segment).
model Sequence {
  id        String   @id @default(cuid())
  key       String   @unique // matches an ICP segment key
  name      String
  channel   String   @default("multi") // email | linkedin | sms | multi
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]
}

// One touch within a sequence.
model SequenceStep {
  id         String   @id @default(cuid())
  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  order      Int
  channel    String   @default("email") // email | linkedin | sms
  delayDays  Int      @default(0) // days to wait after the previous step
  subject    String? // email only
  body       String // supports {{firstName}}, {{company}} tokens

  @@unique([sequenceId, order])
}

// Tracks one lead moving through one sequence.
model SequenceEnrollment {
  id           String    @id @default(cuid())
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequenceId   String
  sequence     Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  currentStep  Int       @default(0)
  status       String    @default("active") // active | completed | stopped
  nextActionAt DateTime?
  createdAt    DateTime  @default(now())

  @@unique([leadId, sequenceId])
}

// Working hours we've committed to a partner agency (who may be in another
// timezone). Shown as live clocks + an open/closed indicator. One weekly window.
model AgencySchedule {
  id        String   @id @default(cuid())
  name      String
  timezone  String   // IANA tz, e.g. "Asia/Karachi"
  days      Int[]    // working days, 0=Sun … 6=Sat
  startMin  Int      @default(540)  // window start, minutes from midnight (09:00)
  endMin    Int      @default(1020) // window end, minutes from midnight (17:00)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Append-only log of everything that happens to a lead.
model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String // sourced | scored | email_sent | replied | linkedin_task | note | ...
  channel   String? // email | linkedin | sms
  detail    String?
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}
