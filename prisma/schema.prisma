// Prisma schema for the UA agency platform.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  MANAGER
  PROJECT_MANAGER
  DEVELOPER
  DESIGNER
  SALES
}

// Which discipline a user serves in on a specific project.
enum ProjectRole {
  PROJECT_MANAGER
  DEVELOPER
  DESIGNER
}

enum BudgetType {
  FIXED
  HOURLY
  RETAINER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  ONBOARDING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  roles        Role[]   @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTasks     Task[]             @relation("TaskAssignee")
  timeEntries       TimeEntry[]
  projectMembers    ProjectMember[]
  salesLeads        Client[]           @relation("SalesLeads")
  commissionPayouts CommissionPayout[]
  salaries          Salary[]
  salaryPayments    SalaryPayment[]
  uploadedFiles     FileAsset[]        @relation("UploadedFiles")
  fileComments      FileComment[]      @relation("FileComments")

  @@index([email])
}

model Client {
  id           String        @id @default(cuid())
  // Contact
  name         String        // business / client name
  contactName  String?       // primary contact person
  email        String?
  phone        String?
  source       String?
  sourceOther  String?       // when source = OTHER
  industry     String?
  location     String?       // optional geographic location
  website      String?       // current website
  socialLinks  String?       // free text / links
  notes        String?
  // Lead attribution for sales commission
  leadType      String?
  taxRegion     String?   // 'QC' | 'CA' | 'US' — drives invoice tax
  salespersonId String?
  salesperson   User?     @relation("SalesLeads", fields: [salespersonId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  projects Project[]
  payments Payment[]
  invoices Invoice[]

  @@index([salespersonId])
}

model Project {
  id              String        @id @default(cuid())
  name            String
  type            String
  description     String?
  targetAudience  String?
  referenceLinks  String?

  // Budget
  budgetAmount    Float?
  budgetCurrency  String?       @default("USD")
  budgetType      BudgetType?

  // Timeline
  startDate       DateTime?
  deadline        DateTime?
  priority        Priority      @default(MEDIUM)

  // Assets & links (v1 = links only)
  figmaLink       String?
  fileLinks       String?       // pasted URLs, one per line
  brandAssetsLink String?
  domainAccess    String?       // notes / access for dev projects

  status          ProjectStatus @default(ONBOARDING)
  internalNotes   String?
  pmCommissionRate Float        @default(10) // % of project value / payments to the PM

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  members     ProjectMember[]
  tasks       Task[]
  timeEntries TimeEntry[]
  payments    Payment[]
  invoices    Invoice[]
  files       FileAsset[]

  @@index([clientId])
  @@index([status])
}

// Join: a user assigned to a project in a particular discipline.
// Multiple people per role, and a person could hold multiple roles on a project.
model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectRole
  createdAt DateTime    @default(now())

  @@unique([projectId, userId, role])
  @@index([projectId])
  @@index([userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  tags Tag[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#64748b")
  createdAt DateTime @default(now())

  tasks Task[]
}

// User-editable dropdown options. `kind` groups them (projectType, clientSource,
// expenseCategory, fileCategory, paymentMethod, currency, leadType). `value` is
// the stored string; `label` is shown; `rate` is the commission % for leadType.
// Singleton company profile (used on invoices, receipts, contracts).
model CompanySetting {
  id        String   @id @default("default")
  name      String   @default("UA Agency")
  email     String?
  phone     String?
  website   String?
  address   String?
  gstNumber String?
  qstNumber String?
  neqNumber String?
  gstRate   Float    @default(5)
  qstRate   Float    @default(9.975)
  updatedAt DateTime @updatedAt
}

model OptionItem {
  id        String   @id @default(cuid())
  kind      String
  value     String
  label     String
  rate      Float?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([kind, value])
  @@index([kind])
}

// A recorded commission payout to a team member (sales or PM). Amount in CAD.
model CommissionPayout {
  id        String   @id @default(cuid())
  amount    Float
  paidAt    DateTime
  method    String?
  note      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A file stored in the Google Shared Drive, indexed against a project.
model FileAsset {
  id          String       @id @default(cuid())
  name        String
  category    String       @default("OTHER")
  driveFileId String
  webViewLink String?
  mimeType    String?
  size        Int?
  createdAt   DateTime     @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: SetNull)

  comments FileComment[]

  @@index([projectId])
}

model FileComment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  fileId String
  file   FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?    @relation("FileComments", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([fileId])
}

// An invoice for a project (or client). Number auto-increments.
model Invoice {
  id        String        @id @default(cuid())
  number    Int           @unique @default(autoincrement())
  status    InvoiceStatus @default(DRAFT)
  amount    Float
  currency  String        @default("USD")
  issuedAt  DateTime      @default(now())
  dueAt     DateTime?
  notes     String?
  sentAt    DateTime?
  createdAt DateTime      @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
}

// A business expense (any currency, normalized to CAD).
model Expense {
  id        String          @id @default(cuid())
  title     String
  category  String          @default("OTHER")
  amount    Float
  currency  String          @default("CAD")
  amountCad Float?
  fxRate    Float?
  date      DateTime        // the date the expense applies to
  note      String?
  createdAt DateTime        @default(now())

  @@index([date])
}

// Salary progression: one row per salary change for a user (latest = current).
model Salary {
  id            String   @id @default(cuid())
  amount        Float
  currency      String   @default("CAD")
  effectiveFrom DateTime
  note          String?
  createdAt     DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A salary payment to a user (any currency, normalized to CAD).
model SalaryPayment {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("CAD")
  amountCad Float?
  paidAt    DateTime
  method    String?
  note      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TimeEntry {
  id         String   @id @default(cuid())
  checkInAt  DateTime
  checkOutAt DateTime
  hours      Float
  tasks      String?
  notes      String?
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// A payment received from a client (optionally tied to a specific project).
model Payment {
  id        String        @id @default(cuid())
  amount    Float
  currency  String        @default("USD")
  amountCad Float?        // amount converted to CAD at the rate when recorded
  fxRate    Float?        // currency -> CAD rate used at record time
  method    String        @default("BANK_TRANSFER")
  paidAt    DateTime
  note      String?
  createdAt DateTime      @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
}
