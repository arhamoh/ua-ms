# Copy to .env and fill in. .env is gitignored.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ua:ua_local_dev@localhost:5432/ua_platform?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# ─── Invoicing email — use EITHER Resend OR SMTP/Gmail (SMTP wins if set) ─────
RESEND_API_KEY=""
INVOICE_FROM_EMAIL="invoices@youragency.com"
# Gmail SMTP: host smtp.gmail.com, port 465, user = your address, pass = app password
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── Google Shared Drive ─────────────────────────────────────────────────────
# Full service-account JSON (single line), and the Shared Drive ID
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_SHARED_DRIVE_ID=""

# ─── Analytics chatbot (OpenRouter + Kimi) ───────────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="moonshotai/kimi-k2"
